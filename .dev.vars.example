# Copy to .dev.vars and fill in values from `supabase start` output.
# Wrangler reads this file (not .env.local) for `opennextjs-cloudflare preview`.

# Supabase — from `supabase start` or hosted project dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Read-only production access for agents (SELECT-only Postgres role).
# One-time setup: see docs/agent-read-only-setup.md
# Used by: pnpm sync:prod-to-local, pnpm query:prod
#
# Use Session pooler URL (port 5432, NOT 6543/Transaction).
# Direct connection (db.<ref>.supabase.co) is IPv6-only and fails on IPv4 networks.
AGENT_READ_DATABASE_URL=postgres://agent_reader.<project-ref>:<64-char-hex>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require


# Anthropic — Claude AI for river condition interpretations
ANTHROPIC_API_KEY=

# Cron job protection — any long random string
CRON_SECRET=
