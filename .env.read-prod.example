# Copy to .env.read-prod and fill in the connection string.
#
# This file holds the ONLY production credential that lives on disk: the
# read-only Postgres role used by `pnpm sync:prod-to-local` and
# `pnpm query:prod`. The role has SELECT privileges on the public schema
# only — writes are rejected by Postgres at the role level.
#
# One-time setup of the role: see docs/agent-read-only-setup.md
#
# Use the Session pooler URL (port 5432, NOT 6543/Transaction).
# Direct connection (db.<ref>.supabase.co) is IPv6-only and fails on
# IPv4 networks.
#
# Production WRITE credentials never live in any file on disk — those go
# through `wrangler secret put` only.

AGENT_READ_DATABASE_URL=postgres://agent_reader.<project-ref>:<64-char-hex>@aws-<N>-<region>.pooler.supabase.com:5432/postgres?sslmode=require
