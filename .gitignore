# Dependencies
node_modules/

# Next.js
.next/
out/

# OpenNext / Cloudflare build output
.open-next/
.vercel/

# Wrangler
.wrangler/
worker-configuration.d.ts

# Secrets — never commit
# Env tiers (see .env.development.local.example, .env.read-prod.example):
#   .env.development.local — local-dev credentials (loaded by next dev + wrangler dev via symlink)
#   .env.read-prod         — production SELECT-only Postgres role for sync/query scripts
#   .dev.vars              — symlink to .env.development.local (Wrangler-required filename)
#   .env.local             — legacy, retired in favor of .env.development.local; kept ignored
#                            to catch accidental recreation
.env.local
.env.development.local
.env.read-prod
.dev.vars

# Local prod-snapshot metadata (auto-generated by sync-prod-to-local.sh)
.local-snapshot-info

# Supabase local state
supabase/.branches/
supabase/.temp/

# OS
.DS_Store

# Supabase schema
lib/supabase/types.ts

# Local agent instructions
.agents/

#lighthouse testing
.lighthouseci/

tsconfig.tsbuildinfo

.claude/*
# .claude/settings.json holds team-wide agent permissions (deny rules etc.) —
# COMMIT this file so the rules apply on every fresh clone and every agent
# session. Personal overrides go in .claude/settings.local.json (still ignored).
!.claude/settings.json
.history/
