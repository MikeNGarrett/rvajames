{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "rva-james",
	"main": ".open-next/worker.js",
	"compatibility_date": "2025-05-23",
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"browser": {
		"binding": "BROWSER"
	},
	// SEC-2: in-Worker rate limiting (per-IP, per-route keys — see lib/rate-limit.ts).
	// Counters are per-colo and eventually consistent; limits are abuse damping,
	// not precise accounting. period must be 10 or 60.
	"ratelimits": [
		{
			"name": "PUBLIC_RATE_LIMITER", // public AI routes — generous enough for fast chip-clicking
			"namespace_id": "1001",
			"simple": { "limit": 60, "period": 60 }
		},
		{
			"name": "CRON_RATE_LIMITER", // unauthorized /api/cron/* hits only; scheduled() bypasses via valid secret
			"namespace_id": "1002",
			"simple": { "limit": 10, "period": 60 }
		}
	],
	"vars": {
		// SEC-3(c): daily Anthropic spend ceiling — above this, public routes serve
		// stale/deterministic content and make zero AI calls until the next UTC day.
		"AI_DAILY_COST_CEILING_USD": "5",
		"NEXT_PUBLIC_SUPABASE_URL": "https://buokjdntsitjpqfjxano.supabase.co",
		"NEXT_PUBLIC_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJ1b2tqZG50c2l0anBxZmp4YW5vIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk1NjQ5MjQsImV4cCI6MjA5NTE0MDkyNH0.4KXgpNc0bquaUhOu6mNba0H65r2WfKYt4c8wIups3jw"
	},
	"triggers": {
		"crons": [
			"*/15 * * * *", // /api/cron/usgs           — USGS gage data (every 15 min)
			"0 * * * *",    // /api/cron/nws             — NWS weather/alerts + NOAA AHPS forecast (hourly)
			"0 3 * * *",    // /api/cron/usgs-percentiles — USGS historical percentiles (daily 3am)
			"0 12 * * *",   // /api/cron/jra             — JRA water quality (daily noon)
			"0 6,18 * * *"  // /api/cron/cso             — RVA CSO advisories (6am + 6pm)
		]
	},
	"observability": {
		"enabled": false,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": false,
			"persist": true,
			"head_sampling_rate": 1
		}
	}
}
