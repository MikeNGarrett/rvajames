# Copy to .env.development.local and fill in values from `supabase status` output.
#
# This is the SINGLE source of truth for local-dev credentials. Both `next dev`
# and `wrangler dev` read it:
#   - Next 9+ auto-loads .env.development.local when NODE_ENV=development.
#   - `.dev.vars` is a symlink to this file, so Wrangler reads the same content.
# Eliminates the parity-drift problem the two-file setup had.
#
# NEVER add production credentials here. Production secrets live ONLY in
# `wrangler secret put` (encrypted at the edge). The one exception — a read-only
# Postgres role for sync/query scripts — lives in .env.read-prod, not here.

# Supabase — from `supabase status` (local stack)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — Claude AI for river condition interpretations
ANTHROPIC_API_KEY=

# Cron job protection — any long random string. Used by both next dev and
# wrangler dev. For local dev a memorable string is fine; production uses a
# real secret set via `wrangler secret put CRON_SECRET`.
CRON_SECRET=
