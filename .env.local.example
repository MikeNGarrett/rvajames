# Copy to .env.local and fill in values from `supabase start` output.
# Used by `next dev`. Wrangler reads .dev.vars instead.

# Supabase — from `supabase start` or hosted project dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — Claude AI for river condition interpretations
ANTHROPIC_API_KEY=

# Cron job protection — any long random string
CRON_SECRET=
